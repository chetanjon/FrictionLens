# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Encryption key for user API keys (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=

# Optional: fallback Gemini key for demo/free tier
GOOGLE_GENERATIVE_AI_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://frictionlens.app

# Analytics (PostHog) — leave blank to disable
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Slack alerts — leave blank to disable
SLACK_WEBHOOK_URL=

# Reddit OAuth (script app) — required for the "Reddit" review source.
# Create a script app at https://www.reddit.com/prefs/apps and paste the
# client id (under the app name) and the secret. Leave blank to hide the
# Reddit tab in the New Analysis dialog.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
